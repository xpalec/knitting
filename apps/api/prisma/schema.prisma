// Knitting Encyclopedia — Prisma Schema
// Data model: 03-data-model.md v2.4
// Generator: prisma-client (Prisma 7)

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum SkillLevel {
  beginner
  intermediate
  advanced
  expert
}

enum EntryStatus {
  draft
  review
  published
  deprecated
}

enum TranslationStatus {
  draft
  reviewed
  published
}

enum CategoryStatus {
  draft
  published
}

enum CategoryType {
  entry
  abbreviation
  article
}

enum RelationType {
  synonym
  antonym
  prerequisite
  variant_regional
  variant_technique
  broader
  narrower
}

enum MediaType {
  image
  diagram
  video_clip
  chart
}


enum ContributionType {
  entry
  translation
  correction
}

enum UserRole {
  editor
  reviewer
  admin
}

// ---------------------------------------------------------------------------
// Entry
// The core encyclopedia entry. No slug, no term — those live in Translation.
// ---------------------------------------------------------------------------

model Entry {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// FK to the EntryTemplate that defines the block structure for this entry
  entry_template_id String?        @db.Uuid
  /// BCP-47 code of the tradition this entry originates from: en, pl, no, de, fr
  origin_language   String
  status            EntryStatus    @default(draft)
  /// Language-independent structured properties (skill_level, definition_short, etc.)
  metadata          Json           @default("{}")
  /// Ordered ContentBlock[] layout manifest — admin-controlled; no translated content here
  content_blocks    Json           @default("[]")
  created_at        DateTime       @default(now()) @db.Timestamptz
  updated_at        DateTime       @updatedAt @db.Timestamptz
  published_at      DateTime?      @db.Timestamptz

  entry_template    EntryTemplate? @relation(fields: [entry_template_id], references: [id], onDelete: SetNull)
  translations      Translation[]
  media_assets      MediaAsset[]
  pattern_usage     PatternUsage[]
  categories        EntryCategory[]
  tags              EntryTag[]
  related_from      RelatedEntry[]  @relation("RelatedFrom")
  related_to        RelatedEntry[]  @relation("RelatedTo")
  contributions     Contribution[]
  learning_path_entries LearningPathEntry[]

  @@index([origin_language])
  @@index([entry_template_id])
  @@map("entry")
}

// ---------------------------------------------------------------------------
// Translation
// All locale-specific content: display name, slug, metadata, block content.
// One row per locale per entry.
// ---------------------------------------------------------------------------

model Translation {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entry_id        String            @db.Uuid
  /// BCP-47 locale code: en, pl, de, no, fr, en-US, en-GB
  locale          String
  /// Locale-specific public URL slug — immutable once published
  slug            String
  /// Display name in this locale
  term            String
  /// Locale-specific structured properties: abbreviation, definition_short
  metadata        Json              @default("{}")
  /// Translated block content keyed by ContentBlock.id
  blocks          Json              @default("{}")
  translator_note String?
  status          TranslationStatus @default(draft)
  /// Maintained by trigger: indexes term + metadata->>'definition_short' + all text nodes in blocks
  search_vector   Unsupported("tsvector")?

  entry Entry @relation(fields: [entry_id], references: [id], onDelete: Cascade)

  @@unique([entry_id, locale])
  @@unique([locale, slug])
  @@index([search_vector], type: Gin)
  @@index([blocks(ops: JsonbOps)], type: Gin)
  @@index([metadata(ops: JsonbOps)], type: Gin)
  @@map("translation")
}

// ---------------------------------------------------------------------------
// Category
// Hierarchical taxonomy via self-join parent_id. 2–3 levels recommended.
// Display names, slugs, and descriptions live in CategoryTranslation.
// ---------------------------------------------------------------------------

model Category {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type            CategoryType
  parent_id       String?        @db.Uuid
  icon            String?
  sort_order      Int            @default(0)
  status          CategoryStatus @default(draft)
  /// Denormalised count of published entries — maintained by application logic on EntryCategory changes
  entry_count     Int            @default(0)
  /// Optional CDN URL (Cloudflare R2) for richer category landing pages
  cover_image_url String?
  /// Accent color hex — used in UI badges and category cards. Randomly assigned on creation.
  color           String?
  /// Open-ended language-independent properties. GIN-indexed.
  metadata        Json           @default("{}")
  created_at      DateTime       @default(now()) @db.Timestamptz
  updated_at      DateTime       @updatedAt @db.Timestamptz

  parent       Category?             @relation("CategoryChildren", fields: [parent_id], references: [id])
  children     Category[]            @relation("CategoryChildren")
  entries      EntryCategory[]
  articles     Article[]
  translations CategoryTranslation[]

  @@index([parent_id])
  @@index([type])
  @@index([status])
  @@map("category")
}

// ---------------------------------------------------------------------------
// CategoryTranslation
// All locale-specific content for a category: name, slug, rich-text description.
// One row per locale per category.
// ---------------------------------------------------------------------------

model CategoryTranslation {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category_id       String            @db.Uuid
  /// BCP-47 locale code: en, pl, de, no, fr
  locale            String
  /// Locale-specific public URL slug, e.g. "sciegi" (pl), "stitches" (en)
  slug              String
  /// Display name in this locale
  name              String
  /// TipTap JSON — editorial introduction. Same node schema as the definition content block. Nullable.
  description       Json?
  /// Plain-text one-line summary for the category — shown in cards and previews. Nullable.
  short_description String?
  /// Locale-specific <title> override for the category page (≤60 chars). Falls back to name. Nullable.
  seo_title         String?
  /// Locale-specific meta description for the category page (≤160 chars). Nullable.
  seo_description   String?
  status            TranslationStatus @default(draft)
  translator_note   String?
  created_at        DateTime          @default(now()) @db.Timestamptz
  updated_at        DateTime          @updatedAt @db.Timestamptz

  category Category @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@unique([category_id, locale])
  @@unique([locale, slug])
  @@index([locale])
  @@map("category_translation")
}

model EntryCategory {
  entry_id    String @db.Uuid
  category_id String @db.Uuid

  entry    Entry    @relation(fields: [entry_id], references: [id], onDelete: Cascade)
  category Category @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@id([entry_id, category_id])
  @@map("entry_category")
}

// ---------------------------------------------------------------------------
// Tag
// Lightweight cross-cutting labels. Display names live in TagTranslation.
// ---------------------------------------------------------------------------

model Tag {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Canonical English kebab-case identifier — never changes (e.g. "wool", "dpn", "fair-isle")

  entries      EntryTag[]
  articles     ArticleTag[]
  translations TagTranslation[]

  @@map("tag")
}

// ---------------------------------------------------------------------------
// TagTranslation
// Locale-specific content for a tag: name, description, SEO fields.
// One row per locale per tag.
// ---------------------------------------------------------------------------

model TagTranslation {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tag_id          String            @db.Uuid
  /// BCP-47 locale code: en, pl, de, no, fr
  locale          String
  /// Locale-specific public URL slug, e.g. "welna" (pl), "wool" (en)
  slug            String
  /// Display name in this locale, e.g. "wełna" (pl), "wool" (en)
  name            String
  /// TipTap JSON — editorial description shown on the public tag page. Nullable.
  description     Json?
  /// Locale-specific <title> override for the tag page (≤60 chars). Falls back to name.
  seo_title       String?
  /// Locale-specific meta description for the tag page (≤160 chars).
  seo_description String?
  status          TranslationStatus @default(draft)
  created_at      DateTime          @default(now()) @db.Timestamptz
  updated_at      DateTime          @updatedAt @db.Timestamptz

  tag Tag @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@unique([tag_id, locale])
  @@unique([locale, slug])
  @@index([locale])
  @@map("tag_translation")
}

model EntryTag {
  entry_id String @db.Uuid
  tag_id   String @db.Uuid

  entry Entry @relation(fields: [entry_id], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([entry_id, tag_id])
  @@map("entry_tag")
}

// ---------------------------------------------------------------------------
// RelatedEntry
// Self-join on Entry modelling relationships between terms.
// ---------------------------------------------------------------------------

model RelatedEntry {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entry_id      String       @db.Uuid
  related_id    String       @db.Uuid
  relation_type RelationType
  /// "symmetric" or "directed"
  direction     String       @default("symmetric")
  note          String?

  entry   Entry @relation("RelatedFrom", fields: [entry_id], references: [id], onDelete: Cascade)
  related Entry @relation("RelatedTo", fields: [related_id], references: [id], onDelete: Cascade)

  @@map("related_entry")
}

// ---------------------------------------------------------------------------
// MediaAsset
// CDN URL is locale-independent. Alt text and caption live in Translation.blocks.
// ---------------------------------------------------------------------------

model MediaAsset {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entry_id   String    @db.Uuid
  type       MediaType
  /// CDN URL (Cloudflare R2) — locale-independent
  url        String
  sort_order Int       @default(0)

  entry Entry @relation(fields: [entry_id], references: [id], onDelete: Cascade)

  @@map("media_asset")
}

// ---------------------------------------------------------------------------
// PatternUsage
// Records how an entry appears in real-world knitting patterns.
// ---------------------------------------------------------------------------

model PatternUsage {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entry_id     String      @db.Uuid
  pattern_name String
  /// FK to a future Pattern master table — nullable until that table exists
  pattern_id   String?     @db.Uuid
  /// How the entry is specifically used — the most editorially valuable field
  context_note String
  /// How many times the entry appears; drives usage bar charts
  frequency    Int
  /// Context-sensitive override of Entry.metadata.skill_level
  skill_level  SkillLevel?

  entry Entry @relation(fields: [entry_id], references: [id], onDelete: Cascade)

  @@map("pattern_usage")
}

// ---------------------------------------------------------------------------
// ContentBlockType
// Registry of named, typed reusable block structures (e.g. rich_text, callout).
// Human-readable labels and per-locale headings live in ContentBlockTypeTranslation.
// ---------------------------------------------------------------------------

model ContentBlockType {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Machine-readable slug, e.g. "rich_text". Pattern: [a-z][a-z0-9_]*. Unique.
  type        String   @unique
  /// Human-readable label shown in the admin UI, e.g. "Rich Text"
  label       String   @db.VarChar(255)
  /// Optional editorial note for admins
  description String?  @db.Text
  /// Accent color hex from the shared APP_COLORS palette (optional)
  color       String?
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @updatedAt @db.Timestamptz

  translations ContentBlockTypeTranslation[]

  @@map("content_block_type")
}

// ---------------------------------------------------------------------------
// ContentBlockTypeTranslation
// Locale-specific heading for a ContentBlockType (e.g. "Treść" for rich_text in pl).
// One row per locale per block type.
// ---------------------------------------------------------------------------

model ContentBlockTypeTranslation {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  block_type_id    String   @db.Uuid
  /// BCP-47 locale code: en, pl
  locale           String
  /// Translated heading shown to readers as the section title for this block
  heading          String   @db.VarChar(255)
  created_at       DateTime @default(now()) @db.Timestamptz
  updated_at       DateTime @updatedAt @db.Timestamptz

  block_type ContentBlockType @relation(fields: [block_type_id], references: [id], onDelete: Cascade)

  @@unique([block_type_id, locale])
  @@index([locale])
  @@map("content_block_type_translation")
}

// ---------------------------------------------------------------------------
// EntryTemplate
// Named, managed templates — each holds an ordered list of Template_Block_Item
// references assigned to one entry type. Identified by id, no slug, no translations.
// ---------------------------------------------------------------------------

model EntryTemplate {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Human-readable name, e.g. "Technique – Step-by-Step Guide" (≤255 chars)
  name        String   @db.VarChar(255)
  /// Optional editorial description for admins (≤1000 chars)
  description String?  @db.Text
  /// Ordered array of { id: uuid, type: string, order: number, required: boolean }
  blocks      Json     @default("[]")
  /// Nested translation defaults: { [blockId]: { [locale]: { [fieldName]: string } } }
  translations Json    @default("{}")
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @updatedAt @db.Timestamptz

  entries     Entry[]

  @@map("entry_template")
}

// ---------------------------------------------------------------------------
// BlockTemplate
// Default content_blocks array per entry type. Applied when creating new entries.
// Changes do NOT retroactively update existing entries.
// ---------------------------------------------------------------------------

model BlockTemplate {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// e.g. stitch, technique, tool, tradition, yarn_weight
  entry_type String   @unique
  /// Default ContentBlock[] — all visible: true, block IDs pre-generated, no content
  blocks     Json     @default("[]")
  updated_at DateTime @updatedAt @db.Timestamptz

  @@map("block_template")
}

// ---------------------------------------------------------------------------
// Article
// Long-form editorial content — technique deep-dives, regional histories.
// slug, title, and content live in ArticleTranslation (one row per locale).
// content_blocks is the shared layout manifest — same structure for all locales;
// per-locale heading + rich-text content for each block lives in
// ArticleTranslation.blocks (keyed by block id), mirroring Entry/Translation.
// ---------------------------------------------------------------------------

model Article {
  id                   String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// FK to Category (type = article). Nullable — an article may be uncategorised.
  category_id          String?     @db.Uuid
  /// BCP-47 code of the locale this article was originally authored in
  origin_language      String      @default("en")
  cover_image_url      String?
  author               String?
  country_code         String?
  /// Ordered ContentBlock[] layout manifest — same for all locales
  content_blocks       Json        @default("[]")
  status               EntryStatus @default(draft)
  published_at         DateTime?   @db.Timestamptz
  created_at           DateTime    @default(now()) @db.Timestamptz
  updated_at           DateTime    @updatedAt @db.Timestamptz

  category     Category?           @relation(fields: [category_id], references: [id], onDelete: SetNull)
  translations ArticleTranslation[]
  tags         ArticleTag[]

  @@index([category_id])
  @@index([status])
  @@map("article")
}

// ---------------------------------------------------------------------------
// ArticleTranslation
// All locale-specific content: title, slug, short description, SEO fields,
// and per-block translated content.  One row per locale per article.
// ---------------------------------------------------------------------------

model ArticleTranslation {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  article_id        String            @db.Uuid
  /// BCP-47 locale code: en, pl, de, no, fr
  locale            String
  /// Locale-specific public URL slug — immutable once published
  slug              String
  /// Display title in this locale
  title             String
  /// Plain-text one-line summary shown in cards and previews
  short_description String?
  /// Translated block content keyed by ContentBlock.id
  /// Shape: { [blockId]: { heading?: string; content?: TipTap JSON } }
  blocks            Json              @default("{}")
  /// Locale-specific <title> override for the article page (≤60 chars)
  seo_title         String?
  /// Locale-specific meta description for the article page (≤160 chars)
  seo_description   String?
  translator_note   String?
  status            TranslationStatus @default(draft)
  created_at        DateTime          @default(now()) @db.Timestamptz
  updated_at        DateTime          @updatedAt @db.Timestamptz

  article Article @relation(fields: [article_id], references: [id], onDelete: Cascade)

  @@unique([article_id, locale])
  @@unique([locale, slug])
  @@index([locale])
  @@map("article_translation")
}

model ArticleTag {
  article_id String @db.Uuid
  tag_id     String @db.Uuid

  article Article @relation(fields: [article_id], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([article_id, tag_id])
  @@map("article_tag")
}

// ---------------------------------------------------------------------------
// LearningPath
// Curated ordered sequences of entries.
// ---------------------------------------------------------------------------

model LearningPath {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug              String     @unique
  title             String
  description       String
  skill_level_min   SkillLevel
  skill_level_max   SkillLevel
  /// Denormalised; computed from entry count
  estimated_minutes Int
  published         Boolean    @default(false)

  entries LearningPathEntry[]

  @@map("learning_path")
}

model LearningPathEntry {
  path_id    String @db.Uuid
  entry_id   String @db.Uuid
  sort_order Int

  path  LearningPath @relation(fields: [path_id], references: [id], onDelete: Cascade)
  entry Entry        @relation(fields: [entry_id], references: [id], onDelete: Cascade)

  @@id([path_id, entry_id])
  @@map("learning_path_entry")
}

// ---------------------------------------------------------------------------
// Contribution
// Pending public submissions — entries, translations, corrections.
// ---------------------------------------------------------------------------

model Contribution {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type            ContributionType
  /// pending | approved | rejected
  status          String           @default("pending")
  /// Submitted data, shaped per type
  payload         Json
  /// Set for translation and correction submissions
  entry_id        String?          @db.Uuid
  submitter_email String?
  reviewer_note   String?
  submitted_at    DateTime         @default(now()) @db.Timestamptz
  reviewed_at     DateTime?        @db.Timestamptz

  entry Entry? @relation(fields: [entry_id], references: [id], onDelete: SetNull)

  @@map("contribution")
}

// ---------------------------------------------------------------------------
// User
// Editorial team members. Not exposed to public readers.
// ---------------------------------------------------------------------------

model User {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String   @unique
  name          String
  role          UserRole
  password_hash String
  created_at    DateTime @default(now()) @db.Timestamptz

  @@map("user")
}
